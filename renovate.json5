{
  $schema: 'https://docs.renovatebot.com/renovate-schema.json',
  extends: ['config:recommended', ':dependencyDashboard', ':semanticCommits'],

  // Schedule inherited from central config.js (before 4am UTC on weekdays)

  labels: ['dependencies'],

  packageRules: [
    // Python
    {
      description: 'Group non-major Python dependency updates',
      matchManagers: ['pep621', 'uv'],
      matchUpdateTypes: ['minor', 'patch'],
      groupName: 'non-major Python dependencies',
      minimumReleaseAge: '3 days',
    },

    // GitHub Actions
    {
      description: 'Group non-major GitHub Actions updates',
      matchManagers: ['github-actions'],
      matchUpdateTypes: ['minor', 'patch', 'pin', 'digest'],
      groupName: 'non-major GitHub Actions',
      minimumReleaseAge: '3 days',
    },

    // Docker
    {
      description: 'Group non-major Docker dependency updates',
      matchManagers: ['dockerfile'],
      matchUpdateTypes: ['minor', 'patch', 'pin', 'digest'],
      groupName: 'non-major Docker dependencies',
      minimumReleaseAge: '3 days',
    },

    // Major updates always separate for manual review
    {
      description: 'Separate major updates for manual review',
      matchUpdateTypes: ['major'],
      groupName: null,
    },

    // Security
    {
      description: 'Prioritise security updates',
      matchCategories: ['security'],
      groupName: null,
      labels: ['dependencies', 'security'],
      minimumReleaseAge: null,
      prPriority: 10,
    },
  ],

  vulnerabilityAlerts: {
    labels: ['security'],
    minimumReleaseAge: null,
  },
}
